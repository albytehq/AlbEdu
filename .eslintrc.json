{
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }],
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["warn", "always"],
    "no-undef": "off",
    "no-redeclare": "error",
    "semi": ["error", "always"],
    "no-multiple-empty-lines": ["warn", { "max": 2 }],
    "no-trailing-spaces": "warn",
    "eol-last": ["error", "always"]
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    "public/QNotify/",
    "supabase/functions/"
  ]
}
