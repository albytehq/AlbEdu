{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@auth/*":      ["src/auth/*"],
      "@wizard/*":    ["src/wizard/*"],
      "@exam/*":      ["src/exam/*"],
      "@identity/*":  ["src/identity/*"],
      "@profile/*":   ["src/profile/*"],
      "@pages/*":     ["src/pages/*"],
      "@utils/*":     ["src/utils/*"],
      "@styles/*":    ["styles/*"],
      "@public/*":    ["public/*"]
    },
    "checkJs": false,
    "allowJs": true,
    "jsx": "preserve"
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "public/QNotify", "supabase/functions"]
}
